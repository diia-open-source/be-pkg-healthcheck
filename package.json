{
    "name": "@diia-inhouse/healthcheck",
    "version": "1.16.1",
    "description": "Healthcheck",
    "main": "dist/index.js",
    "types": "dist/types/index.d.ts",
    "repository": "https://github.com/diia-open-source/be-pkg-healthcheck.git",
    "author": "Diia",
    "license": "SEE LICENSE IN LICENSE.md",
    "files": [
        "dist",
        "proto"
    ],
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "prebuild": "rimraf dist",
        "build": "npm run genproto && npx tsc",
        "semantic-release": "semantic-release",
        "lint": "eslint . && prettier --check . && buf format ./proto --diff --exit-code",
        "lint-fix": "eslint . --fix && prettier --write . && buf format ./proto --write",
        "lint:lockfile": "lockfile-lint --path package-lock.json --allowed-hosts registry.npmjs.org --validate-https",
        "prepare": "npm run build",
        "test": "vitest run",
        "test:watch": "vitest watch",
        "find-circulars": "madge --circular --extensions ts ./",
        "genproto": "npx genproto --outputDir src/generated"
    },
    "dependencies": {
        "@bufbuild/protobuf": "2.11.0",
        "@grpc/proto-loader": "0.8.0",
        "lodash": "4.17.23"
    },
    "peerDependencies": {
        "@diia-inhouse/types": ">=3.0.0",
        "@diia-inhouse/utils": ">=2.11.0"
    },
    "devDependencies": {
        "@bufbuild/buf": "1.66.0",
        "@diia-inhouse/configs": "6.1.1",
        "@diia-inhouse/errors": "1.17.0",
        "@diia-inhouse/eslint-config": "8.2.4",
        "@diia-inhouse/genproto": "3.0.1",
        "@diia-inhouse/test": "7.2.0",
        "@diia-inhouse/types": "11.3.0",
        "@diia-inhouse/utils": "5.3.0",
        "@diia-inhouse/validators": "1.28.0",
        "@grpc/grpc-js": "1.14.3",
        "@types/lodash": "4.17.24",
        "@types/node": "22.19.13",
        "@vitest/coverage-v8": "4.0.18",
        "@vitest/ui": "4.0.18",
        "eslint": "9.39.3",
        "glob": "11.1.0",
        "lockfile-lint": "5.0.0",
        "madge": "8.0.0",
        "rimraf": "6.1.3",
        "semantic-release": "24.2.9",
        "type-fest": "5.4.4",
        "vite-tsconfig-paths": "6.1.1",
        "vitest": "4.0.18",
        "vitest-mock-extended": "3.1.0"
    },
    "release": {
        "extends": "@diia-inhouse/configs/dist/semantic-release/package"
    },
    "commitlint": {
        "extends": "@diia-inhouse/configs/dist/commitlint"
    },
    "prettier": "@diia-inhouse/eslint-config/prettier",
    "overrides": {
        "esbuild": "0.27.3"
    }
}
